document.getElementById('donationForm').addEventListener('submit', function(event) {
    event.preventDefault(); // Stops the page from reloading

    // 1. Get the selected payment method
    const paymentMethod = document.querySelector('input[name="DonationPayment"]:checked').value;

    // 2. Logic based on selection
    if (paymentMethod === 'card') {
        alert('Redirecting to secure card payment...');
        // Insert your Payment Gateway logic here (e.g., Paystack, Flutterwave, Stripe)
    } else {
        alert('Please transfer to Providus Bank: 1308815727');
        // You could show a hidden <div> with the full bank details here
    }
});
